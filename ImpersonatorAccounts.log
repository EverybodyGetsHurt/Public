CREATE TABLE oauth10a_accounts (
	id INTEGER NOT NULL, 
	email VARCHAR, 
	previous_twitter_account_info VARCHAR, 
	twitter_account_id VARCHAR, 
	PRIMARY KEY (id), 
	FOREIGN KEY(twitter_account_id) REFERENCES twitter_accounts (twitter_id)
)


