INFO:sqlalchemy.engine.Engine:
CREATE TABLE twitter_accounts (
	id INTEGER NOT NULL, 
	twitter_id VARCHAR, 
	protected_channel VARCHAR, 
	username VARCHAR NOT NULL, 
	name VARCHAR, 
	created_at DATETIME, 
	description VARCHAR, 
	followers_count INTEGER, 
	following_count INTEGER, 
	tweet_count INTEGER, 
	listed_count INTEGER, 
	suspended BOOLEAN, 
	suspended_date DATETIME, 
	rechecked_suspended_state DATETIME, 
	username_changed BOOLEAN, 
	username_changed_to VARCHAR, 
	username_changed_date DATETIME, 
	unresolvable BOOLEAN, 
	api_response JSON, 
	api_response_updated_at DATETIME, 
	previous_api_response JSON, 
	previous_api_response_updated_at DATETIME, 
	url VARCHAR, 
	profile_image_url VARCHAR, 
	PRIMARY KEY (id), 
	UNIQUE (twitter_id), 
	UNIQUE (username)
)


